PORT=5000
MONGO_URI=mongodb://localhost:27017/darklight_photography
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173

# Cloudinary (optional - leave blank to use local storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=DarkLight Photography <your_email@gmail.com>

NODE_ENV=development
